PORT=3000
NODE_ENV=development

# Comma-separated allowed origins to append to built-in defaults
CLIENT_ORIGIN=http://localhost:5173

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase (server-side service role)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Email (optional, contact/order emails disabled if missing)
RESEND_API_KEY=re_...

# Rate limits (optional overrides)
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=1200
CHECKOUT_RATE_LIMIT_WINDOW_MS=600000
CHECKOUT_RATE_LIMIT_MAX=100
CONTACT_RATE_LIMIT_WINDOW_MS=600000
CONTACT_RATE_LIMIT_MAX=50
ADMIN_RATE_LIMIT_WINDOW_MS=600000
ADMIN_RATE_LIMIT_MAX=30
